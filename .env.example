# ── Database ──────────────────────────────────────────────────────────────────
# Local Postgres (default) or a Supabase/Neon connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/agent_world"

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Required for agents to think. Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=""
DEFAULT_MODEL="gpt-4o-mini"

# ── Agent Guardrails ──────────────────────────────────────────────────────────
EXECUTION_MODE="supervised_live"
ALLOW_REAL_WORLD_ACTIONS="true"
REQUIRE_HUMAN_APPROVAL="true"
ALLOW_WEB_SEARCH="true"
REQUIRE_APPROVAL_FOR_WEB_SEARCH="true"
OPENAI_MONTHLY_BUDGET="10"
MAX_AGENT_RUNS_PER_DAY="20"
MAX_WEB_SEARCHES_PER_DAY="5"
MAX_DAILY_SPEND_WITHOUT_APPROVAL="0"

# ── Cron Security ─────────────────────────────────────────────────────────────
# Secures the POST /api/agent-tick endpoint used by Vercel Cron.
# Generate with: openssl rand -hex 32
# Must match the Authorization: Bearer <secret> header Vercel sends.
CRON_SECRET=""

# ── Stripe ────────────────────────────────────────────────────────────────────
# Test keys (default). Get from: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
# Webhook signing secret — from Stripe dashboard > Developers > Webhooks > your endpoint
# For local dev use: stripe listen --forward-to localhost:3000/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=""
STRIPE_MODE="test"
# Live keys — only set when STRIPE_MODE=live
STRIPE_LIVE_SECRET_KEY=""
STRIPE_LIVE_PUBLISHABLE_KEY=""

# ── Slack ─────────────────────────────────────────────────────────────────────
# Option A: Bot token (recommended — supports reading replies for YES/NO approval)
# Create a Slack app at https://api.slack.com/apps → Bot Token Scopes: chat:write, channels:history
SLACK_BOT_TOKEN=""
SLACK_CHANNEL_ID=""            # Channel ID (e.g. C0B9UN9V92B), not #channel-name
SLACK_SIGNING_SECRET=""        # From Slack app > Basic Information > App Credentials
# Option B: Incoming webhook (simpler — send-only, cannot read replies)
SLACK_WEBHOOK_URL=""
SLACK_APPROVAL_CHANNEL_ID=""

# ── Web Search ────────────────────────────────────────────────────────────────
# Agents can search the web. Provide at least one key (Brave preferred).
# Brave: https://api.search.brave.com/  |  Serper: https://serper.dev/
BRAVE_SEARCH_API_KEY=""
SERPER_API_KEY=""

# ── Email (Resend) ────────────────────────────────────────────────────────────
# For agent-drafted emails once approved. Get from: https://resend.com/api-keys
RESEND_API_KEY=""

# ── Vercel Deployment ─────────────────────────────────────────────────────────
# Used by the Website Agent to deploy landing pages.
# Get from: https://vercel.com/account/tokens
VERCEL_TOKEN=""

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Optional password to gate the dashboard (set empty to disable)
APP_PASSWORD=""
